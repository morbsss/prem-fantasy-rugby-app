# Production environment variables
# Copy to .env.production (gitignored) and fill in real values,
# OR set these directly in the Vercel dashboard under Project → Settings → Environment Variables.

DB_TYPE=postgres
ALLOW_UNRESTRICTED_EDITS=false
SECRET_KEY=<generate a strong random key>

# Neon / Vercel Postgres connection strings
DATABASE_URL=postgresql://<user>:<password>@<host>/<database>?sslmode=require
DATABASE_URL_UNPOOLED=postgresql://<user>:<password>@<host-unpooled>/<database>?sslmode=require

# Individual connection params (optional, if needed by Vercel Postgres integration)
PGHOST=
PGHOST_UNPOOLED=
PGUSER=
PGDATABASE=
PGPASSWORD=
POSTGRES_URL=
POSTGRES_URL_NON_POOLING=
POSTGRES_USER=
POSTGRES_HOST=
POSTGRES_PASSWORD=
POSTGRES_DATABASE=
