{
  "buildCommand": "cd api && pip install -r requirements.txt && cd ..",
  "outputDirectory": "api",
  "env": {
    "DB_TYPE": "postgres",
    "ALLOW_UNRESTRICTED_EDITS": "false",
    "PYTHONUNBUFFERED": "1"
  },
  "crons": [
    {
      "path": "/api/cron/tick",
      "schedule": "*/5 * * * *"
    }
  ]
}
