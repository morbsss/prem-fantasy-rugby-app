{
  "buildCommand": "cd api && pip install -r requirements.txt && cd ..",
  "outputDirectory": "api",
  "env": {
    "DB_TYPE": "postgres",
    "ALLOW_UNRESTRICTED_EDITS": "false",
    "PYTHONUNBUFFERED": "1"
  },
  "crons": [
    {
      "path": "/api/cron/player-data",
      "schedule": "0 12 * * 2"
    }
  ]
}
